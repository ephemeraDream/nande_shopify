<div class="spring-offer-bar">

<span class="spring-offer-text">
🌸 Spring Offer
</span>

<div class="spring-offer-code">

<span id="springCode">SPRING15</span>

<button class="spring-copy-btn" onclick="copySpringCode()">
Copy
</button>

</div>

</div>

<style>

.spring-offer-bar{
display:flex;
justify-content:space-between;
align-items:center;
margin-top:12px;
padding:10px 14px;
border:1px solid #e6e6e6;
border-radius:6px;
background:#fafafa;
font-size:13px;
}

.spring-offer-text{
font-weight:500;
color:#444;
}

.spring-offer-code{
display:flex;
align-items:center;
gap:8px;
}

#springCode{
font-weight:600;
letter-spacing:1px;
}

.spring-copy-btn{
border:1px solid #111;
background:#111;
color:#fff;
font-size:12px;
padding:4px 10px;
cursor:pointer;
border-radius:4px;
}

.spring-copy-btn:hover{
background:#333;
}

</style>

<script>

function copySpringCode(){

var code=document.getElementById("springCode").innerText;

navigator.clipboard.writeText(code);

var btn=document.querySelector(".spring-copy-btn");

btn.innerText="Copied";

setTimeout(function(){

btn.innerText="Copy";

},2000);

}

</script>